# ── Copy this file to .env and fill in your values ───────────────
# Never commit .env to git!

# Script generation (get free key at console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Stock footage (get free key at pexels.com/api)
PEXELS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# YouTube OAuth (path to downloaded client_secrets.json)
CLIENT_SECRETS_FILE=client_secrets.json

# Optional: use local Ollama instead of Groq
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
